# ==================== 服务器配置 ====================
PORT=8080
NODE_ENV=development

# ==================== JWT 配置 ====================
# ⚠️ 必须使用强随机密钥，可通过 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" 生成
JWT_SECRET=<YOUR_JWT_SECRET_HERE>
JWT_REFRESH_SECRET=<YOUR_JWT_REFRESH_SECRET_HERE>
JWT_ACCESS_TOKEN_EXPIRY=2h
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ACCESS_EXPIRY=2h
JWT_REFRESH_EXPIRY=7d

# ==================== CSRF 配置 ====================
CSRF_SECRET=<YOUR_CSRF_SECRET_HERE>

# ==================== API 配置 ====================
API_BASE_URL=
PUBLIC_API_BASE_URL=http://localhost:8080
API_PROTOCOL=http
API_HOST=localhost

# ==================== MySQL 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<YOUR_DB_PASSWORD_HERE>
DB_NAME=mes

# 数据库连接池配置
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=20
DB_CONNECT_TIMEOUT=60000
DB_MAX_IDLE=8
DB_IDLE_TIMEOUT=600000

# Sequelize连接池配置
SEQUELIZE_POOL_MAX=10
SEQUELIZE_POOL_MIN=2
SEQUELIZE_POOL_ACQUIRE=60000
SEQUELIZE_POOL_IDLE=600000
SEQUELIZE_POOL_EVICT=300000

# ==================== Redis 配置 (可选) ====================
# 如果 Redis 服务未启动，系统会自动降级到内存缓存
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD_HERE>
REDIS_DB=0

# ==================== 文件上传配置 ====================
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=uploads

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log
ENABLE_DEBUG_LOG=false
ENABLE_SQL_LOG=false

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== 速率限制配置 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# ==================== 本地 Ollama AI 配置 ====================
# Ollama 服务地址（OpenAI 兼容 API），用于预算AI分析和8D报告生成
OLLAMA_API_URL=http://127.0.0.1:11434/v1/chat/completions
OLLAMA_MODEL=<YOUR_OLLAMA_MODEL>
OLLAMA_TIMEOUT_MS=300000

# ==================== 天气API配置 (可选) ====================
# 高德地图天气API，注册地址: https://lbs.amap.com/
AMAP_API_KEY=<YOUR_AMAP_API_KEY_HERE>

# ==================== 市场价格配置 (可选) ====================
METAL_PRICE_EXCHANGE_RATE_URL=https://api.frankfurter.app/latest?from=USD&to=CNY
METAL_PRICE_USD_CNY_FALLBACK=7.24
METAL_PRICE_REFRESH_CRON="0 */4 * * *"
METAL_PRICE_STARTUP_DELAY_MS=5000
METAL_PRICE_GOLD_REFERENCE_CNY_PER_OZ=34529.35
METAL_PRICE_PLATINUM_REFERENCE_CNY_PER_OZ=9020
METAL_PRICE_ALUMINUM_REFERENCE_CNY_PER_TON=19150
METAL_PRICE_COPPER_REFERENCE_CNY_PER_TON=69200
METAL_PRICE_GOLD_USD_PER_OZ=2050
METAL_PRICE_PLATINUM_USD_PER_OZ=950

# ==================== Ollama OCR 配置 (可选) ====================
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_OCR_MODEL=deepseek-ocr:latest
OLLAMA_TIMEOUT=60000

# ==================== 钉钉开放平台配置 (可选) ====================
DINGTALK_APP_KEY=<YOUR_DINGTALK_APP_KEY_HERE>
DINGTALK_APP_SECRET=<YOUR_DINGTALK_APP_SECRET_HERE>
DINGTALK_DEFAULT_DEPT_ID=<YOUR_DINGTALK_DEPARTMENT_ID_HERE>

# ==================== Swagger 文档配置 (可选) ====================
# 非生产环境下，访问 /api-docs 需要的认证凭据
SWAGGER_USER=<YOUR_SWAGGER_USER_HERE>
SWAGGER_PASSWORD=<YOUR_SWAGGER_PASSWORD_HERE>
SWAGGER_API_BASE_URL=http://localhost:8080/api
SWAGGER_PRODUCTION_API_BASE_URL=
