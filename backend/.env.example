# --- 钉钉集成 ---
DINGTALK_AGENT_ID=
DINGTALK_API_TOKEN=your_dingtalk_api_token_here
DINGTALK_APP_KEY=your_dingtalk_app_key_here
DINGTALK_APP_SECRET=your_dingtalk_app_secret_here
DINGTALK_CALLBACK_AES_KEY=your_dingtalk_callback_aes_key_here
DINGTALK_CALLBACK_TOKEN=your_dingtalk_callback_token_here
DINGTALK_CORP_ID=
DINGTALK_DEFAULT_DEPT_ID=
DINGTALK_PROCESS_CODE=

# --- AI 服务 (Ollama) ---
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=gemma4:26b
OLLAMA_TIMEOUT_MS=

# --- Swagger 文档 ---
SWAGGER_API_BASE_URL=
SWAGGER_PASSWORD=your_swagger_password_here
SWAGGER_PRODUCTION_API_BASE_URL=
SWAGGER_USER=

# --- 定时任务 ---
DISABLE_CRON=

# --- 备份 ---
BACKUP_DIR=

# --- 其他 ---
ENABLE_DEBUG_LOG=
SEQUELIZE_POOL_MAX=
SEQUELIZE_RETRY_MAX=
