METAL_PRICE_GOLD_REFERENCE_CNY_PER_OZ=
METAL_PRICE_GOLD_USD_PER_OZ=
METAL_PRICE_PLATINUM_REFERENCE_CNY_PER_OZ=
METAL_PRICE_PLATINUM_USD_PER_OZ=
METAL_PRICE_REFRESH_CRON=0 */4 * * *
METAL_PRICE_STARTUP_DELAY_MS=
