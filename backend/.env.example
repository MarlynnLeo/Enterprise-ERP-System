# ============================================================
# ERP 系统环境变量配置模板
# 复制此文件为 .env 并根据实际环境修改
# ============================================================

# --- 服务器 ---
ALLOWED_ORIGINS=
API_BASE_URL=
API_HOST=localhost
API_PROTOCOL=http
DEBUG_MODE=
NODE_ENV=development
PORT=8080
PUBLIC_API_BASE_URL=http://localhost:8080

# --- 数据库 ---
DB_ACQUIRE_TIMEOUT=
DB_CONNECTION_LIMIT=
DB_HOST=localhost
DB_MAX_HOLD_TIME=
DB_MAX_IDLE=
DB_NAME=mes
DB_PASSWORD=your_db_password_here
DB_PORT=3306
DB_USER=root

# --- 认证与安全 ---
CSRF_SECRET=your_csrf_secret_here
ENABLE_CSRF=
JWT_ACCESS_EXPIRY=2h
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_SECRET=your_jwt_secret_here
LOGIN_LOCK_DURATION_MINUTES=
LOGIN_MAX_FAILED_ATTEMPTS=

# --- Redis 缓存 ---
REDIS_DB=0
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379
REDIS_USERNAME=erp_app

# --- 限流 ---
ENABLE_RATE_LIMIT=
RATE_LIMIT_MAX_REQUESTS=
RATE_LIMIT_WINDOW_MS=

# --- 输入验证 ---
ENABLE_INPUT_SANITIZATION=
ENABLE_SUSPICIOUS_ACTIVITY_DETECTION=
VALIDATION_AMOUNT_PRECISION=
VALIDATION_MAX_FILE_SIZE=
VALIDATION_STOCK_PRECISION=

# --- 日志 ---
ENABLE_SQL_LOG=
LOG_LEVEL=

# --- 财务模块 ---
FINANCE_ACCOUNT_DEFAULT_ACTIVE=
FINANCE_ACCOUNT_DEFAULT_CURRENCY=CNY
FINANCE_ADDITIONAL_TAX_RATE=
FINANCE_ALLOW_AUTO_CREATE_ACCOUNT=
FINANCE_ALLOW_NEGATIVE_BALANCE=
FINANCE_AMOUNT_PRECISION=
FINANCE_AP_PREFIX=AP
FINANCE_AR_PREFIX=AR
FINANCE_AUTO_GET_CURRENT_PERIOD=
FINANCE_DEFAULT_CREATOR=system
FINANCE_DEFAULT_CURRENCY=CNY
FINANCE_DEFAULT_EXCHANGE_RATE=AR
FINANCE_DEFAULT_OPERATOR=system
FINANCE_DEFAULT_PAGE_SIZE=10,20,50,100
FINANCE_DEFAULT_PAYMENT_TERMS=30天付款
FINANCE_DEFAULT_PAYMENT_TERM_DAYS=
FINANCE_DEFAULT_PERIOD_ID=
FINANCE_DEFAULT_VAT_RATE=0,0.03,0.06,0.09,0.13
FINANCE_ENFORCE_BALANCED_ENTRY=
FINANCE_EXCHANGE_RATE_PRECISION=
