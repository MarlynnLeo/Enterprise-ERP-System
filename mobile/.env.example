# ==================== 移动端环境变量配置示例 ====================
# 复制此文件为 .env 并修改相应的配置

# ==================== API 配置 ====================
# API 基础 URL
# ⚠️ 重要: 生产环境请使用域名而非 IP 地址
# 开发环境示例: http://127.0.0.1:8080
# 生产环境示例: https://api.yourdomain.com 或 /api (使用相对路径)
VITE_APP_API_BASE_URL=http://127.0.0.1:8080
VITE_API_TARGET=http://127.0.0.1:8080

# ==================== 开发服务器配置 ====================
# Vite 开发服务器主机地址
VITE_DEV_HOST=0.0.0.0

# Vite 开发服务器端口
VITE_DEV_PORT=3001

# ==================== 应用信息 ====================
# 应用名称
VITE_APP_NAME=KACON-ERP移动端

# 应用版本
VITE_APP_VERSION=1.0.0
VITE_APP_HOMEPAGE=

# ==================== 功能开关 ====================
# 启用 PWA (渐进式 Web 应用)
VITE_ENABLE_PWA=true

# 启用离线模式
VITE_ENABLE_OFFLINE=false

# 启用调试模式
VITE_ENABLE_DEBUG=true
