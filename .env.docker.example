# ==================== Docker Compose 环境变量 ====================
# 复制此文件为 .env（与 docker-compose.yml 同级）并填入真实值
# ⚠️ .env 文件绝不可提交到 Git 仓库

# 数据库密码
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_NAME=mes
DB_PASSWORD=<YOUR_DB_PASSWORD_HERE>

# JWT 密钥（使用 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" 生成）
JWT_SECRET=<YOUR_JWT_SECRET_HERE>
JWT_REFRESH_SECRET=<YOUR_JWT_REFRESH_SECRET_HERE>

# CSRF 密钥
CSRF_SECRET=<YOUR_CSRF_SECRET_HERE>

# CORS 白名单，多个来源用英文逗号分隔
ALLOWED_ORIGINS=https://erp.yourdomain.com
PUBLIC_API_BASE_URL=https://api.yourdomain.com

# 本地 Ollama AI（用于预算分析和8D报告生成）
OLLAMA_API_URL=http://host.docker.internal:11434/v1/chat/completions
OLLAMA_MODEL=gemma4:26b

# 高德地图天气 API Key（可选）
AMAP_API_KEY=

# 市场价格配置（可选）
METAL_PRICE_EXCHANGE_RATE_URL=https://api.frankfurter.app/latest?from=USD&to=CNY
METAL_PRICE_USD_CNY_FALLBACK=7.24
METAL_PRICE_REFRESH_CRON="0 */4 * * *"
METAL_PRICE_STARTUP_DELAY_MS=5000
METAL_PRICE_GOLD_REFERENCE_CNY_PER_OZ=34529.35
METAL_PRICE_PLATINUM_REFERENCE_CNY_PER_OZ=9020
METAL_PRICE_ALUMINUM_REFERENCE_CNY_PER_TON=19150
METAL_PRICE_COPPER_REFERENCE_CNY_PER_TON=69200
METAL_PRICE_GOLD_USD_PER_OZ=2050
METAL_PRICE_PLATINUM_USD_PER_OZ=950

# Redis
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD_HERE>

# Ollama OCR 配置
OLLAMA_HOST=http://host.docker.internal:11434
