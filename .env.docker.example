# ==================== Docker Compose 环境变量 ====================
# 复制此文件为 .env（与 docker-compose.yml 同级）并填入真实值
# ⚠️ .env 文件绝不可提交到 Git 仓库

# 数据库密码
DB_PASSWORD=<YOUR_DB_PASSWORD_HERE>

# JWT 密钥（使用 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" 生成）
JWT_SECRET=<YOUR_JWT_SECRET_HERE>
JWT_REFRESH_SECRET=<YOUR_JWT_REFRESH_SECRET_HERE>

# CSRF 密钥
CSRF_SECRET=<YOUR_CSRF_SECRET_HERE>

# 智谱AI API Key（可选）
ZHIPU_API_KEY=

# 高德地图天气 API Key（可选）
AMAP_API_KEY=

# Redis
REDIS_HOST=192.168.1.251
REDIS_PORT=6379
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD_HERE>

# SiliconFlow API Key（可选）
SILICONFLOW_API_KEY=
