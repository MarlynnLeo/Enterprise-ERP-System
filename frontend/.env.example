# ============================================
# ERP 前端环境变量配置模板
# 复制此文件为 .env.local 并填入实际值
# ============================================

# API 基础地址（用于 axios 实例和文件上传）
# 开发环境示例: http://localhost:8080
# 生产环境通常留空，由 nginx 反代处理
VITE_API_URL=http://localhost:8080

# API 基础路径前缀（用于 request.js 的 axios 实例）
# 默认为 /api
VITE_API_BASE_URL=/api
